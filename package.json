{
  "name": "zai-code-bot",
  "version": "0.0.1",
  "description": "GitHub Action for PR auto-review and /zai assistant commands powered by Z.ai",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --license licenses.txt",
    "test": "c8 --reporter=text --reporter=lcov node --test 'tests/**/*.test.js'"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^8.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "c8": "^11.0.0",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "@actions/http-client": "3.0.2",
    "undici": "6.23.0"
  },
  "c8": {
    "include": [
      "src/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true
  }
}
